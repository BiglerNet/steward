# Copy to `.env` (gitignored) and adjust as needed. Defaults below are safe for local dev.

# --- Postgres ---
POSTGRES_DB=steward
POSTGRES_USER=steward
POSTGRES_PASSWORD=steward

# --- Api ---
# Host is the Compose service name "postgres", not localhost — the api container
# reaches Postgres over the Compose network, not via the host-published port.
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=steward;Username=steward;Password=steward
Jwt__Key=dev-only-change-me-in-production-min-32ch
Cors__AllowedOrigins__0=http://localhost:8081
Frontend__BaseUrl=http://localhost:8081
Storage__RootPath=/app/storage
Storage__MaxUploadSizeBytes=10485760

Auth__Google__ClientId=
Auth__Google__ClientSecret=
Auth__Facebook__ClientId=
Auth__Facebook__ClientSecret=
Auth__Apple__ClientId=
Auth__Apple__KeyId=
Auth__Apple__TeamId=

# --- Platform Admin Bootstrap ---
# Set to the email of the first platform administrator. When a user registers with this
# email, they are automatically granted the PlatformAdmin role. Leave empty to disable.
PLATFORMADMIN__EMAIL=

# --- Web ---
# This is read by the browser, so it must be reachable from the host, not the
# Compose-internal service name (the browser cannot resolve "api").
API_BASE_URL=http://localhost:5000

# GitHub PAT (read:packages scope) for installing @biglernet/* packages from
# GitHub Packages during the web image build. Compose passes this in as a
# build secret (see docker-compose.yml), never as an image ENV/ARG, so it
# doesn't get baked into a layer.
BIGLERNET_NPM_TOKEN=
